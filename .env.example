# PostgreSQL Database URL
# Format: postgresql://user:password@host:port/database
# If your password includes reserved URL characters like `$` or `#`, percent-encode
# them in the URL so env loading and URL parsing stay correct. Example:
# `pa$ss#word` -> `pa%24ss%23word`
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/relay_tasks

# OpenAI API Key (for agent calls)
OPENAI_API_KEY=your_openai_api_key_here

# Feature flags (set to "true" to enable)
NEXT_PUBLIC_FEATURE_INITIATIVES=false
